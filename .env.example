# AlphaBasket Environment Config
# COPY this file to .env and fill in your details privately.

# The email address you want to SEND from (e.g. rohitgautam0429@gmail.com)
EMAIL_USER=rohitgautam0429@gmail.com

# 16-character Google App Password (NOT your normal password)
# 1. Manage Google Account -> Security -> 2-Step Verification
# 2. Scroll to bottom -> App Passwords
# 3. Create one for "AlphaBasket Bot" and paste here:
EMAIL_PASS=your_16_char_app_password

# Target Receivers (comma separated)
EMAIL_TO=rameshchand1858@gmail.com
